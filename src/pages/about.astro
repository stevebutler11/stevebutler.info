---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Props = CollectionEntry<'posts'>['data'];

const { title, description } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 25%;
				box-shadow: var(--box-shadow);
			}
			img {
				filter: grayscale(1);
			}
			img:hover {
				filter: grayscale(0);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					<img width={300} height={300} src={'/me.jpg'} alt="photo of steve" />
				</div>
				<div class="prose">
					<div class="title">
						<h1>About Me</h1>
						<hr />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>